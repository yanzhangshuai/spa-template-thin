{
  "name": "spa-template-thin",
  "type": "module",
  "version": "1.0.0",
  "author": "yanzhangshuai<yanzhangshuai@126.com>",
  "license": "MIT",
  "repository": "https://github.com/yanzhangshuai/spa-template-thin.git",
  "web-types": "./src/components/web-types.json",
  "scripts": {
    "vue-tsc": "vue-tsc --noEmit --skipLibCheck",
    "vite-build": "vite build --config ./build/vite.config.ts",
    "dev": "vite --config ./build/vite.config.ts",
    "build": "npm-run-all vue-tsc && npm-run-all vite-build",
    "build:gz": "cross-env VITE_GZIP=true vite build --config ./build/vite.config.ts",
    "serve": "npm-run-all vite-build && vite preview --config ./build/vite.config.ts",
    "deploy": "npm-run-all build && docker build -t spa-template-thin -f ./deploy/Dockerfile .",
    "report": "cross-env VITE_REPORT=true vite build --config ./build/vite.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest --passWithNoTests --config ./test/vitest.config.ts"
  },
  "dependencies": {
    "@mwjz/pinia-storage": "^0.0.3",
    "@pinia/plugin-debounce": "^1.0.1",
    "@tanstack/vue-query": "^5.51.15",
    "@vueuse/core": "^10.11.0",
    "ant-design-vue": "4.x",
    "axios": "^1.7.2",
    "crypto-js": "^4.1.1",
    "dayjs": "^1.11.12",
    "less": "^4.1.3",
    "lodash": "^4.17.21",
    "pinia": "^2.2.0",
    "pug": "^3.0.3",
    "typescript": "^5.5.4",
    "unocss": "^0.61.5",
    "vue": "^3.4.34",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^2.23.2",
    "@optimize-lodash/rollup-plugin": "^4.0.4",
    "@types/crypto-js": "^4.1.1",
    "@types/lodash": "^4.17.7",
    "@types/node": "^20.14.12",
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "@vitejs/plugin-legacy": "^5.4.1",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vitejs/plugin-vue-jsx": "^4.0.0",
    "@vue/language-plugin-pug": "^2.0.29",
    "@vue/test-utils": "^2.0.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.7.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globby": "^14.0.2",
    "jsdom": "^24.1.1",
    "npm-run-all": "^4.1.5",
    "open-cli": "^8.0.0",
    "rollup": "^4.19.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "ts-node": "^10.9.1",
    "unplugin-vue-components": "^0.27.3",
    "unplugin-vue-router": "^0.10.1",
    "vite": "^5.3.5",
    "vite-imagetools": "^7.0.4",
    "vite-plugin-compression2": "^1.1.3",
    "vite-plugin-restart": "^0.4.1",
    "vite-plugin-static-copy": "^1.0.6",
    "vitest": "^2.0.4",
    "vue-tsc": "^2.0.29"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint": "9"
      }
    }
  }
}
